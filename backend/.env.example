NODE_ENV=development
PORT=5050
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/meditrust?retryWrites=true&w=majority
JWT_SECRET=replace-with-32-plus-char-random-string
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:4321

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Khalti: get from merchant.khalti.com → API Keys
KHALTI_SECRET_KEY=
# Comma-separated list of Khalti server IPs (optional but recommended)
KHALTI_ALLOWED_IPS=

# Seed script — only needed when running: npm run seed
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_USERNAME=yourusername
SEED_ADMIN_PASSWORD=YourStrongPassword123
